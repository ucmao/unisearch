{
  "name": "unisearch-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "webui:build": "cd webui && npm run build",
    "electron:dev": "electron .",
    "electron:build": "npm run webui:build && electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "mermaid": "^11.12.2",
    "vitepress": "^1.3.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "build": {
    "appId": "com.unisearch.app",
    "productName": "UniSearch",
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/unisearch-backend",
        "to": "unisearch-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  }
}

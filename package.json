{
  "name": "unisearch-desktop",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "scripts": {
    "test:agent": "node --import tsx --test tests/agent-intent.test.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "webui:build": "cd webui && npm run build",
    "build:backend": "tsup",
    "electron:dev": "npm run build:backend && electron .",
    "electron:build": "npm run build:backend && npm run webui:build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "playwright": "^1.45.0",
    "segmentit": "^2.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "mermaid": "^11.12.2",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitepress": "^1.3.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "build": {
    "appId": "com.unisearch.app",
    "productName": "UniSearch",
    "files": [
      "dist/**/*",
      "api/webui/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  }
}
